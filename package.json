    "ci:smoke": "npm run check:smoke"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "nodemailer": "^9.0.3",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
