{
  "name": "stauden-portal",
  "version": "1.0.0",
  "description": "KI-gestützte Bepflanzungsplanung mit Shop-Anbindung",
  "main": "stauden-server.js",
  "scripts": {
    "start": "node stauden-server.js",
    "dev": "nodemon stauden-server.js",
    "check:env": "node scripts/check-env-preflight.js",
    "check:env:strict": "node scripts/check-env-preflight.js --strict",
    "check:smoke": "node scripts/check-api-smoke.js",
    "check:security": "node test_security.js",
