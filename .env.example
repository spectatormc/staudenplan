# Server
PORT=3000
SITE_URL=https://www.staudenplan.de

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# E-Mail (SMTP) — leer lassen zum Testen, dann wird in der Konsole geloggt
EMAIL_HOST=smtp.ionos.de
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=info@deine-domain.de
EMAIL_PASS=dein-passwort

# Wohin sollen Betreiber-Benachrichtigungen?
EMAIL_BETREIBER=info@deine-domain.de

# Admin-Panel Passwort (/admin?pw=...)
ADMIN_PASSWORT=stauden2025

# Brave Search API -- kostenlos registrieren: https://api.search.brave.com
# Kostenlos: 2000 Suchanfragen/Monat (genuegt fuer gelegentliche Updates)
BRAVE_SEARCH_API_KEY=BSA...
